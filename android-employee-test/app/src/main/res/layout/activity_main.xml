<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/appRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#043D2E">

    <WebView
        android:id="@+id/employeeWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/pageProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="#65BB70" />

    <FrameLayout
        android:id="@+id/startupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#043D2E">

        <VideoView
            android:id="@+id/startupVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#043D2E" />

        <ProgressBar
            android:id="@+id/startupProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_gravity="bottom"
            android:indeterminate="true"
            android:indeterminateTint="#65E88D" />
    </FrameLayout>
</FrameLayout>
